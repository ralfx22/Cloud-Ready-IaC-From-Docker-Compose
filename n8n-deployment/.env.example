# Directory where n8n stores its internal data (workflows, credentials, etc.)
N8N_DATA_DIR=~/n8n

# Directory used as the shared workspace during pipeline runs (Compose input, manifests, Terraform code)
N8N_SHARED_DIR=~/n8n/shared

# Directory containing the k3d kubeconfig (must have k3d.yaml inside)
N8N_KUBECONFIG_DIR=~/n8n/kubeconfig
