            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"sts:AssumeRoleWithWebIdentity\",\n      \"Principal\": {\n        \"Federated\": \"arn:aws:iam::329153220860:oidc-provider/oidc.eks.eu-central-1.amazonaws.com/id/26047D0EF9EDF81608F1A5427FCB51D2\"\n      },\n      \"Condition\": {\n        \"StringEquals\": {\n          \"oidc.eks.eu-central-1.amazonaws.com/id/26047D0EF9EDF81608F1A5427FCB51D2:aud\": \"sts.amazonaws.com\",\n          \"oidc.eks.eu-central-1.amazonaws.com/id/26047D0EF9EDF81608F1A5427FCB51D2:sub\": \"system:serviceaccount:kube-system:aws-load-balancer-controller\"\n        }\n      }\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Action\":\"sts:AssumeRoleWithWebIdentity\",\"Principal\":{\"Federated\":\"arn:aws:iam::329153220860:oidc-provider/oidc.eks.eu-central-1.amazonaws.com/id/26047D0EF9EDF81608F1A5427FCB51D2\"},\"Condition\":{\"StringEquals\":{\"oidc.eks.eu-central-1.amazonaws.com/id/26047D0EF9EDF81608F1A5427FCB51D2:aud\":\"sts.amazonaws.com\",\"oidc.eks.eu-central-1.amazonaws.com/id/26047D0EF9EDF81608F1A5427FCB51D2:sub\":\"system:serviceaccount:kube-system:aws-load-balancer-controller\"}}}]}",
